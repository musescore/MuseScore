            "autorepeat": 0
        },
        {

            "command": "command://playback/loop-toggle",
            "sequences": [],
            "autorepeat": 0
        },
        {

            "command": "command://playback/metronome-toggle",
            "sequences": [],
            "autorepeat": 0
        }
